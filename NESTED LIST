if __name__ == '__main__':
    students = []
    for _ in range(int(input())):
        name = input()
        score = float(input())
        students.append([name, score])

    unique_grades = sorted(list(set([x[1] for x in students])))
    second_lowest_grade = unique_grades[1]

    second_lowest_students = sorted([x[0] for x in students if x[1] == second_lowest_grade])

    for name in second_lowest_students:
        print(name)

